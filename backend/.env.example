# PostgreSQL
POSTGRES_USER=richard_med
POSTGRES_PASSWORD=richard_med
POSTGRES_DB=richard_med
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# App
PROJECT_NAME=Richard Med
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173

# Geocoding (optional — offline address→lat/lng). Leave empty to use seeded coords.
YANDEX_GEOCODER_API_KEY=
YANDEX_GEOCODER_URL=https://geocode-maps.yandex.ru/v1

# LLM match arbitration (optional — offline catalog-grow only, never the user path).
# Leave the key empty to disable; gray-zone aliases stay pending instead.
# Any model on the Gemini API works, e.g. gemini-2.5-flash-lite or gemma-3-27b-it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models
# Min seconds between verify calls to respect free-tier RPM (e.g. 15 RPM → 4; 0 = off).
GEMINI_MIN_INTERVAL_SEC=4.5

# --- Auth (native email/password) ---
# Signs our JWTs — set a long random value in prod: `openssl rand -base64 48`
AUTH_SECRET=dev-secret-change-me-to-a-long-random-value-in-prod
# Emails that get the admin role on sign-up
ADMIN_EMAILS=aidyn.fatikh@gmail.com,apasdauren70@gmail.com
