VITE_API_BASE_URL=http://localhost:8001/api/v1

# --- Auth (client) ---
# Better Auth server URL. Prod: same-origin /api/auth (leave unset). Dev: point to your
# local auth server / `vercel dev` origin.
VITE_AUTH_URL=http://localhost:5173/api/auth
# Local-dev ONLY: skip auth so admin pages are reachable without the auth server running.
# Never set in production (it's compiled out of prod builds anyway).
VITE_DEV_ADMIN=false

# --- Auth server (Vercel serverless functions read these via process.env) ---
# Long random string: `openssl rand -base64 32`
BETTER_AUTH_SECRET=
# Public URL of the auth server (same origin as the app)
BETTER_AUTH_URL=http://localhost:5173
# Comma-separated origins allowed to use the auth API
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173
# From the Better Auth dashboard (the dash() infra plugin)
BETTER_AUTH_API_KEY=
# Postgres for Better Auth tables (can be the same DB as the backend)
DATABASE_URL=postgresql://user:pass@localhost:5432/medtech
# Who gets the admin role on sign-up
ADMIN_EMAILS=aidyn.fatikh@gmail.com,apasdauren70@gmail.com
